@model List<Supplier>
@{ ViewData["Title"] = "Pemasok"; }

<div class="card">
    <div class="card-header justify-content-between">
        <span>Daftar Pemasok</span>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Tambah Pemasok</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>Kode</th><th>Nama</th><th>Kontak</th><th>Email</th><th>Telepon</th><th>Status</th><th class="text-end">Aksi</th></tr></thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-4">Belum ada data</td></tr>
            }
            @foreach (var s in Model)
            {
                <tr>
                    <td><span class="badge-light-primary px-2 py-1 rounded">@s.Code</span></td>
                    <td class="fw-semibold text-dark">@s.Name</td>
                    <td>@s.ContactPerson</td>
                    <td>@s.Email</td>
                    <td>@s.Phone</td>
                    <td>
                        @if (s.IsActive) { <span class="badge-light-success px-2 py-1 rounded">Aktif</span> }
                        else { <span class="badge-light-danger px-2 py-1 rounded">Nonaktif</span> }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-light"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus pemasok ini?');">
                            <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
