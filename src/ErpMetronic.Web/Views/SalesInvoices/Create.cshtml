@using ErpMetronic.Domain.Entities
@model SalesInvoiceCreateViewModel
@{
    ViewData["Title"] = "Buat Faktur Penjualan";
    var so = ViewBag.SalesOrder as SalesOrder;
    var invoiceable = ViewBag.Invoiceable as Dictionary<int, int> ?? new();
    var names = so?.Items.ToDictionary(i => i.ProductId, i => (i.Product?.Sku + " — " + i.Product?.Name)) ?? new();
    var cur = so?.Currency?.Code;
    var vatTaxes = ViewBag.VatTaxes as IEnumerable<Tax> ?? Enumerable.Empty<Tax>();
    var whtTaxes = ViewBag.WhtTaxes as IEnumerable<Tax> ?? Enumerable.Empty<Tax>();
}

<div class="card">
    <div class="card-header"><i class="bi bi-receipt text-primary me-2"></i> Faktur dari SO @so?.ReferenceNumber — @so?.Customer?.Name</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="SalesOrderId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label asp-for="InvoiceDate" class="form-label fw-semibold"></label>
                    <input asp-for="InvoiceDate" type="date" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label asp-for="Note" class="form-label fw-semibold"></label>
                    <input asp-for="Note" class="form-control" />
                </div>
            </div>

            <div class="alert alert-light border small mb-3">
                <i class="bi bi-info-circle"></i> <strong>3-way matching:</strong> jumlah yang dapat difaktur =
                jumlah <strong>dikirim</strong> dikurangi yang <strong>sudah difaktur</strong>. Anda boleh memfaktur kurang dari itu.
            </div>

            <table class="table align-middle" id="linesTable">
                <thead><tr>
                    <th style="width:30%">Produk</th>
                    <th class="text-end">Maks</th>
                    <th class="text-end" style="width:110px">Jumlah</th>
                    <th class="text-end" style="width:130px">Harga Satuan</th>
                    <th style="width:15%">PPN</th>
                    <th class="text-end">DPP</th>
                    <th class="text-end">PPN Rp</th>
                </tr></thead>
                <tbody id="linesBody">
                @for (int i = 0; i < Model.Lines.Count; i++)
                {
                    var l = Model.Lines[i];
                    var max = invoiceable.TryGetValue(l.ProductId, out var q) ? q : 0;
                    <tr class="line-row">
                        <td>
                            @(names.TryGetValue(l.ProductId, out var nm) ? nm : ("#" + l.ProductId))
                            <input type="hidden" name="Lines[@i].ProductId" value="@l.ProductId" />
                        </td>
                        <td class="text-end fw-semibold">@max</td>
                        <td><input name="Lines[@i].Quantity" type="number" min="0" max="@max" value="@l.Quantity" class="form-control form-control-sm text-end qty" /></td>
                        <td><input name="Lines[@i].UnitPrice" type="number" min="0" step="0.01" value="@l.UnitPrice" class="form-control form-control-sm text-end price" /></td>
                        <td>
                            <select name="Lines[@i].TaxId" class="form-select form-select-sm tax">
                                <option value="" data-rate="0">Tanpa PPN</option>
                                @foreach (var t in vatTaxes)
                                {
                                    <option value="@t.Id" data-rate="@t.Rate" selected="@(t.Id == l.TaxId)">@t.Code (@t.Rate.ToString("0.##")%)</option>
                                }
                            </select>
                        </td>
                        <td class="text-end subtotal">0</td>
                        <td class="text-end linevat text-muted">0</td>
                    </tr>
                }
                </tbody>
            </table>
            <p class="text-muted small">Mata uang: @(cur ?? "—"). Set jumlah 0 untuk baris yang belum ingin difaktur.</p>

            <div class="row mt-3">
                <div class="col-md-5">
                    <label asp-for="WithholdingTaxId" class="form-label fw-semibold"></label>
                    <select asp-for="WithholdingTaxId" class="form-select" id="whtSelect">
                        <option value="" data-rate="0">Tanpa PPh</option>
                        @foreach (var t in whtTaxes)
                        {
                            <option value="@t.Id" data-rate="@t.Rate">@t.Code — @t.Name (@t.Rate.ToString("0.##")%)</option>
                        }
                    </select>
                    <span class="text-muted small">PPh dipotong pelanggan dari nilai dibayar (atas DPP).</span>
                </div>
                <div class="col-md-7">
                    <table class="table table-sm mb-0">
                        <tr><td class="text-end fw-semibold">DPP (Subtotal)</td><td class="text-end" style="width:180px"><span id="sumDpp">0</span></td></tr>
                        <tr><td class="text-end fw-semibold">PPN</td><td class="text-end"><span id="sumVat">0</span></td></tr>
                        <tr><td class="text-end fw-semibold text-danger">PPh dipotong</td><td class="text-end text-danger">−<span id="sumWht">0</span></td></tr>
                        <tr class="table-light"><td class="text-end fw-bold">Total Faktur</td><td class="text-end fw-bold"><span id="sumTotal">0</span></td></tr>
                    </table>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Simpan Faktur</button>
                <a asp-action="SelectSo" class="btn btn-light">Batal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const body = document.getElementById('linesBody');
        const fmt = n => n.toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        const r2 = n => Math.round(n * 100) / 100;
        function recalcAll() {
            let dpp = 0, vat = 0;
            body.querySelectorAll('.line-row').forEach(function (row) {
                const q = parseFloat(row.querySelector('.qty').value) || 0;
                const p = parseFloat(row.querySelector('.price').value) || 0;
                const sub = q * p;
                const sel = row.querySelector('.tax');
                const rate = sel && sel.value ? (parseFloat(sel.selectedOptions[0].dataset.rate) || 0) : 0;
                const lv = r2(sub * rate / 100);
                row.querySelector('.subtotal').textContent = fmt(sub);
                row.querySelector('.linevat').textContent = fmt(lv);
                dpp += sub; vat += lv;
            });
            const wsel = document.getElementById('whtSelect');
            const wrate = wsel && wsel.value ? (parseFloat(wsel.selectedOptions[0].dataset.rate) || 0) : 0;
            const wht = r2(dpp * wrate / 100);
            document.getElementById('sumDpp').textContent = fmt(dpp);
            document.getElementById('sumVat').textContent = fmt(vat);
            document.getElementById('sumWht').textContent = fmt(wht);
            document.getElementById('sumTotal').textContent = fmt(dpp + vat - wht);
        }
        body.addEventListener('input', recalcAll);
        body.addEventListener('change', recalcAll);
        document.getElementById('whtSelect').addEventListener('change', recalcAll);
        recalcAll();
    </script>
}
