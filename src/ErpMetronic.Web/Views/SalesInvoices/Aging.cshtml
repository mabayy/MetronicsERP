@model List<ErpMetronic.Web.Controllers.AgingRow>
@{ ViewData["Title"] = "Umur Piutang (AR)"; }

<div class="card">
    <div class="card-header">
        <span><i class="bi bi-hourglass-split text-primary me-2"></i> Umur Piutang per Pelanggan</span>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr><th>Pelanggan</th><th class="text-end">0–30</th><th class="text-end">31–60</th><th class="text-end">61–90</th><th class="text-end">&gt; 90</th><th class="text-end">Total</th></tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Belum ada piutang</td></tr>
                }
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="fw-semibold text-dark">@r.Partner</td>
                        <td class="text-end">@r.Current.ToString("N2")</td>
                        <td class="text-end">@r.Bucket31.ToString("N2")</td>
                        <td class="text-end">@r.Bucket61.ToString("N2")</td>
                        <td class="text-end">@r.Over90.ToString("N2")</td>
                        <td class="text-end fw-semibold">@r.Total.ToString("N2")</td>
                    </tr>
                }
                </tbody>
                <tfoot>
                    <tr class="table-light">
                        <td class="fw-bold">Total</td>
                        <td class="text-end fw-bold">@Model.Sum(r => r.Current).ToString("N2")</td>
                        <td class="text-end fw-bold">@Model.Sum(r => r.Bucket31).ToString("N2")</td>
                        <td class="text-end fw-bold">@Model.Sum(r => r.Bucket61).ToString("N2")</td>
                        <td class="text-end fw-bold">@Model.Sum(r => r.Over90).ToString("N2")</td>
                        <td class="text-end fw-bold">@Model.Sum(r => r.Total).ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
