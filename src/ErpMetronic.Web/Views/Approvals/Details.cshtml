@using ErpMetronic.Domain.Enums
@model ErpMetronic.Domain.Entities.ApprovalRequest
@{
    ViewData["Title"] = $"Persetujuan {Model.DocumentType} #{Model.ReferenceNumber}";
    var canDecide = ViewBag.CanDecide is bool b && b;
    (string Label, string Css) Badge(ApprovalStatus s) => s switch
    {
        ApprovalStatus.Pending => ("Menunggu", "badge-light-warning"),
        ApprovalStatus.Approved => ("Disetujui", "badge-light-success"),
        ApprovalStatus.Rejected => ("Ditolak", "badge-light-danger"),
        _ => (s.ToString(), "badge-light-primary")
    };
    var hdr = Badge(Model.Status);
}

<div class="card mb-3">
    <div class="card-header justify-content-between">
        <span>Persetujuan @Model.DocumentType #@Model.ReferenceNumber</span>
        <span class="@hdr.Css px-2 py-1 rounded">@hdr.Label</span>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Dokumen</dt><dd class="col-sm-9">@Model.DocumentType</dd>
            <dt class="col-sm-3">Referensi</dt><dd class="col-sm-9">@Model.ReferenceNumber</dd>
            <dt class="col-sm-3">Nilai</dt><dd class="col-sm-9">@Model.Amount.ToString("N2")</dd>
            <dt class="col-sm-3">Status</dt><dd class="col-sm-9"><span class="@hdr.Css px-2 py-1 rounded">@hdr.Label</span></dd>
        </dl>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Langkah Persetujuan</div>
    <div class="card-body p-0">
        <table class="table align-middle mb-0">
            <thead><tr>
                <th>Level</th>
                <th>Jabatan</th>
                <th>Status</th>
                <th>Diputuskan Oleh</th>
                <th>Waktu</th>
                <th>Catatan</th>
            </tr></thead>
            <tbody>
            @foreach (var s in Model.Steps.OrderBy(x => x.Level))
            {
                var sb = Badge(s.Status);
                <tr class="@(Model.Status == ApprovalStatus.Pending && s.Level == Model.CurrentLevel ? "table-warning" : "")">
                    <td>@s.Level</td>
                    <td class="fw-semibold text-dark">@s.Position?.Name</td>
                    <td><span class="@sb.Css px-2 py-1 rounded">@sb.Label</span></td>
                    <td>@s.DecidedBy</td>
                    <td>@(s.DecidedAt.HasValue ? s.DecidedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "—")</td>
                    <td>@s.Note</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (canDecide)
{
    <div class="card mb-3">
        <div class="card-header">Keputusan</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <form asp-action="Approve" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Setujui permintaan ini?');">
                        <input type="text" name="note" class="form-control mb-2" placeholder="Catatan (opsional)" />
                        <button type="submit" class="btn btn-success w-100"><i class="bi bi-check-lg"></i> Setujui</button>
                    </form>
                </div>
                <div class="col-md-6">
                    <form asp-action="Reject" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Tolak permintaan ini?');">
                        <input type="text" name="note" class="form-control mb-2" placeholder="Catatan (opsional)" />
                        <button type="submit" class="btn btn-danger w-100"><i class="bi bi-x-lg"></i> Tolak</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<a asp-action="Index" class="btn btn-light">Kembali</a>
