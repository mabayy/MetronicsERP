@using ErpMetronic.Domain.Enums
@model RequestForQuotation
@{
    ViewData["Title"] = "RFQ " + Model.ReferenceNumber;
    (string Label, string Css) St(RequestForQuotationStatus s) => s switch
    {
        RequestForQuotationStatus.Draft => ("Draft", "badge-light-warning"),
        RequestForQuotationStatus.Sent => ("Terkirim", "badge-light-primary"),
        RequestForQuotationStatus.Closed => ("Ditutup", "badge-light-success"),
        _ => (s.ToString(), "badge-light-primary")
    };
    var st = St(Model.Status);
    var canQuote = Model.Status != RequestForQuotationStatus.Closed;
    var canAward = Model.Status == RequestForQuotationStatus.Sent;
    var canCopyToPo = Model.Status == RequestForQuotationStatus.Closed && Model.Quotes.Any(q => q.IsSelected);
}

<div class="card mb-3">
    <div class="card-header justify-content-between">
        <span>Request for Quotation @Model.ReferenceNumber</span>
        <span class="@st.Css px-2 py-1 rounded">@st.Label</span>
    </div>
    <div class="card-body">
        <dl class="row mb-3">
            <dt class="col-sm-3">Tanggal</dt><dd class="col-sm-9">@Model.RfqDate.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-3">Dari PR</dt><dd class="col-sm-9">@(Model.PurchaseRequisition?.ReferenceNumber ?? "—")</dd>
            <dt class="col-sm-3">Catatan</dt><dd class="col-sm-9">@Model.Note</dd>
        </dl>
        <div class="d-flex gap-2 flex-wrap">
            @if (Model.Status == RequestForQuotationStatus.Draft)
            {
                <form asp-action="Send" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Tandai RFQ terkirim?');">
                    <button class="btn btn-primary btn-sm"><i class="bi bi-send"></i> Tandai Terkirim</button>
                </form>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Hapus RFQ ini?');">
                    <button class="btn btn-light btn-sm text-danger"><i class="bi bi-trash"></i></button>
                </form>
            }
            @if (canCopyToPo)
            {
                <a asp-controller="PurchaseOrders" asp-action="Create" asp-route-fromRfq="@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-arrow-up-right-square"></i> Salin ke PO</a>
            }
            <a asp-action="Index" class="btn btn-light btn-sm">Kembali</a>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Item yang Diminta</div>
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead><tr><th>Produk</th><th class="text-end">Jumlah</th></tr></thead>
                    <tbody>
                    @foreach (var l in Model.Lines)
                    {
                        <tr><td>@l.Product?.Sku — @l.Product?.Name</td><td class="text-end">@l.Quantity.ToString("N0")</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card mb-3">
            <div class="card-header">Penawaran Pemasok</div>
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead><tr><th>Pemasok</th><th class="text-end">Nilai</th><th class="text-end">Lead</th><th></th></tr></thead>
                    <tbody>
                    @if (!Model.Quotes.Any()) { <tr><td colspan="4" class="text-center text-muted py-3">Belum ada penawaran</td></tr> }
                    @foreach (var q in Model.Quotes.OrderBy(q => q.QuotedAmount))
                    {
                        <tr class="@(q.IsSelected ? "table-light" : "")">
                            <td>
                                @q.Supplier?.Name
                                @if (q.IsSelected) { <span class="badge-light-success px-2 rounded ms-1"><i class="bi bi-trophy"></i> Pemenang</span> }
                                @if (!string.IsNullOrEmpty(q.Note)) { <div class="text-muted small">@q.Note</div> }
                            </td>
                            <td class="text-end fw-semibold">@q.QuotedAmount.ToString("N2")</td>
                            <td class="text-end text-muted">@(q.LeadTimeDays.HasValue ? q.LeadTimeDays + "h" : "—")</td>
                            <td class="text-end">
                                @if (canAward && !q.IsSelected)
                                {
                                    <form asp-action="Award" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Pilih penawaran ini sebagai pemenang? RFQ akan ditutup.');">
                                        <input type="hidden" name="quoteId" value="@q.Id" />
                                        <button class="btn btn-sm btn-success"><i class="bi bi-trophy"></i> Pilih</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        @if (canQuote)
        {
            <div class="card">
                <div class="card-header">Tambah Penawaran</div>
                <div class="card-body">
                    <form asp-action="AddQuote" method="post" class="row g-2">
                        <input type="hidden" name="RequestForQuotationId" value="@Model.Id" />
                        <div class="col-12">
                            <label class="form-label small fw-semibold mb-1">Pemasok</label>
                            <select name="SupplierId" asp-items="ViewBag.Suppliers" class="form-select form-select-sm"><option value="">-- Pilih pemasok --</option></select>
                        </div>
                        <div class="col-7">
                            <label class="form-label small fw-semibold mb-1">Nilai Penawaran</label>
                            <input name="QuotedAmount" type="number" min="0.01" step="0.01" class="form-control form-control-sm text-end" />
                        </div>
                        <div class="col-5">
                            <label class="form-label small fw-semibold mb-1">Lead (hari)</label>
                            <input name="LeadTimeDays" type="number" min="0" class="form-control form-control-sm text-end" />
                        </div>
                        <div class="col-12">
                            <input name="Note" class="form-control form-control-sm" placeholder="Catatan (opsional)" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-plus-lg"></i> Tambah Penawaran</button>
                        </div>
                    </form>
                    @if (Model.Status == RequestForQuotationStatus.Draft)
                    {
                        <p class="text-muted small mt-2 mb-0"><i class="bi bi-info-circle"></i> Tandai RFQ <strong>Terkirim</strong> untuk dapat memilih pemenang.</p>
                    }
                </div>
            </div>
        }
    </div>
</div>
