@using ErpMetronic.Domain.Enums
@model PurchaseInvoice
@{
    ViewData["Title"] = "Faktur " + Model.ReferenceNumber;
    var cur = Model.Currency?.Code;
    (string Label, string Css) St(PurchaseInvoiceStatus s) => s switch
    {
        PurchaseInvoiceStatus.Unpaid => ("Belum Dibayar", "badge-light-danger"),
        PurchaseInvoiceStatus.PartiallyPaid => ("Dibayar Sebagian", "badge-light-warning"),
        PurchaseInvoiceStatus.Paid => ("Lunas", "badge-light-success"),
        _ => (s.ToString(), "badge-light-primary")
    };
    var st = St(Model.Status);
}

<div class="card mb-3">
    <div class="card-header justify-content-between">
        <span>Faktur Pembelian @Model.ReferenceNumber</span>
        <span class="@st.Css px-2 py-1 rounded">@st.Label</span>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Tanggal</dt><dd class="col-sm-9">@Model.InvoiceDate.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-3">Pemasok</dt><dd class="col-sm-9">@Model.Supplier?.Name</dd>
            <dt class="col-sm-3">Dari PO</dt><dd class="col-sm-9">@Model.PurchaseOrder?.ReferenceNumber</dd>
            <dt class="col-sm-3">Catatan</dt><dd class="col-sm-9">@Model.Note</dd>
        </dl>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header">Item Faktur</div>
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead><tr><th>Produk</th><th class="text-end">Jumlah</th><th class="text-end">Harga</th><th class="text-end">Subtotal</th></tr></thead>
                    <tbody>
                    @foreach (var l in Model.Lines)
                    {
                        <tr>
                            <td>@l.Product?.Sku — @l.Product?.Name</td>
                            <td class="text-end">@l.Quantity.ToString("N0")</td>
                            <td class="text-end">@l.UnitPrice.ToString("N2")</td>
                            <td class="text-end">@((l.Quantity * l.UnitPrice).ToString("N2"))</td>
                        </tr>
                    }
                    </tbody>
                    <tfoot>
                        <tr class="table-light"><td colspan="3" class="text-end fw-bold">Total</td><td class="text-end fw-bold">@cur @Model.Total.ToString("N2")</td></tr>
                        <tr><td colspan="3" class="text-end">Dibayar</td><td class="text-end">@Model.PaidAmount.ToString("N2")</td></tr>
                        <tr><td colspan="3" class="text-end fw-bold">Sisa Tagihan</td><td class="text-end fw-bold text-danger">@cur @Model.Outstanding.ToString("N2")</td></tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card mb-3">
            <div class="card-header">Pembayaran</div>
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead><tr><th>No.</th><th>Tanggal</th><th class="text-end">Jumlah</th></tr></thead>
                    <tbody>
                    @if (!Model.Payments.Any())
                    {
                        <tr><td colspan="3" class="text-center text-muted py-3">Belum ada pembayaran</td></tr>
                    }
                    @foreach (var p in Model.Payments.OrderBy(p => p.Id))
                    {
                        <tr><td class="fw-semibold">@p.ReferenceNumber</td><td>@p.PaymentDate.ToString("dd/MM/yyyy")</td><td class="text-end">@p.Amount.ToString("N2")</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.Status != PurchaseInvoiceStatus.Paid)
        {
            <div class="card">
                <div class="card-header">Catat Pembayaran</div>
                <div class="card-body">
                    <form asp-action="Pay" method="post">
                        <input type="hidden" name="PurchaseInvoiceId" value="@Model.Id" />
                        <div class="mb-2">
                            <label class="form-label fw-semibold small mb-1">Tanggal</label>
                            <input name="PaymentDate" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label fw-semibold small mb-1">Jumlah (sisa @Model.Outstanding.ToString("N2"))</label>
                            <input name="Amount" type="number" min="0.01" step="0.01" max="@Model.Outstanding" value="@Model.Outstanding" class="form-control form-control-sm text-end" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label fw-semibold small mb-1">Metode</label>
                            <input name="Method" class="form-control form-control-sm" placeholder="Transfer / Tunai" />
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-cash-coin"></i> Bayar</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
<div class="mt-3"><a asp-action="Index" class="btn btn-light">Kembali</a></div>
