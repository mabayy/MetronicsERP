@model List<ErpMetronic.Domain.Entities.CashBankAccount>
@{ ViewData["Title"] = "Akun Kas & Bank"; }

<div class="card">
    <div class="card-header justify-content-between">
        <span>Akun Kas & Bank</span>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Akun Baru</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead><tr>
                <th>Kode</th>
                <th>Nama</th>
                <th>Jenis</th>
                <th>Akun GL</th>
                <th>Bank</th>
                <th>No. Rek</th>
                <th>Status</th>
                <th class="text-end">Aksi</th>
            </tr></thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-4">Belum ada data</td></tr>
            }
            @foreach (var a in Model)
            {
                <tr>
                    <td>
                        <span class="badge-light-primary px-2 py-1 rounded">@a.Code</span>
                        @if (a.IsSystem) { <span class="text-muted small ms-1">sistem</span> }
                    </td>
                    <td class="fw-semibold text-dark">@a.Name</td>
                    <td>
                        @if (a.Kind == ErpMetronic.Domain.Entities.CashBankAccountKind.Cash)
                        {
                            <span class="badge-light-success px-2 py-1 rounded">Kas</span>
                        }
                        else
                        {
                            <span class="badge-light-primary px-2 py-1 rounded">Bank</span>
                        }
                    </td>
                    <td><span class="text-muted">@a.AccountCode</span></td>
                    <td>@(a.BankName ?? "—")</td>
                    <td>@(a.AccountNumber ?? "—")</td>
                    <td>
                        @if (a.IsActive) { <span class="badge-light-success px-2 py-1 rounded">Aktif</span> }
                        else { <span class="badge-light-danger px-2 py-1 rounded">Nonaktif</span> }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-light"><i class="bi bi-pencil"></i></a>
                        @if (!a.IsSystem)
                        {
                            <form asp-action="Delete" asp-route-id="@a.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus akun ini?');">
                                <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        }
                        else
                        {
                            <span class="btn btn-sm btn-light text-muted disabled"><i class="bi bi-lock"></i></span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
