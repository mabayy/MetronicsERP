@model List<ErpMetronic.Web.Controllers.InventoryValuationRow>
@{
    ViewData["Title"] = "Nilai Persediaan";
    var baseCur = ViewBag.BaseCurrency as Currency;
    var dp = baseCur?.DecimalPlaces ?? 0;
    var sym = baseCur?.Symbol;
    var grand = (decimal)ViewBag.GrandTotal;
}

<div class="card">
    <div class="card-header justify-content-between">
        <span><i class="bi bi-cash-stack text-primary me-2"></i> Nilai Persediaan (qty × harga beli)</span>
        <a asp-action="Card" class="btn btn-sm btn-light"><i class="bi bi-card-list"></i> Kartu Stok</a>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end mb-3">
            <div class="col-sm-5 col-md-4">
                <label class="form-label small fw-semibold mb-1">Gudang</label>
                <select name="warehouseId" asp-items="ViewBag.Warehouses" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Semua gudang</option>
                </select>
            </div>
            <div class="col-auto"><a asp-action="Valuation" class="btn btn-sm btn-light">Reset</a></div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr><th>SKU</th><th>Produk</th><th>Gudang</th><th class="text-end">Qty</th><th class="text-end">Harga Beli/unit (@baseCur?.Code)</th><th class="text-end">Nilai (@baseCur?.Code)</th></tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Belum ada stok</td></tr>
                }
                @foreach (var r in Model)
                {
                    <tr>
                        <td><span class="badge-light-primary px-2 py-1 rounded">@r.Sku</span></td>
                        <td class="fw-semibold text-dark">@r.ProductName</td>
                        <td>@r.Warehouse</td>
                        <td class="text-end">@r.Quantity.ToString("N0")</td>
                        <td class="text-end">@(r.UnitCostBase.HasValue ? sym + " " + r.UnitCostBase.Value.ToString("N" + dp) : "—")</td>
                        <td class="text-end fw-semibold">
                            @if (r.Value.HasValue) { <text>@sym @r.Value.Value.ToString("N" + dp)</text> }
                            else { <span class="text-danger">kurs belum ada</span> }
                        </td>
                    </tr>
                }
                </tbody>
                <tfoot>
                    <tr class="table-light">
                        <td colspan="5" class="text-end fw-bold">Total Nilai Persediaan</td>
                        <td class="text-end fw-bold">@sym @grand.ToString("N" + dp)</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
