@using ErpMetronic.Domain.Enums
@model List<StockMovement>
@{
    ViewData["Title"] = "Riwayat Stok";
    var filterType = ViewBag.FilterType as MovementType?;
}

@functions {
    (string Label, string Css, string Icon) TypeInfo(MovementType t) => t switch
    {
        MovementType.StockIn => ("Masuk", "badge-light-success", "bi-box-arrow-in-down"),
        MovementType.StockOut => ("Keluar", "badge-light-danger", "bi-box-arrow-up"),
        MovementType.Transfer => ("Transfer", "badge-light-primary", "bi-arrow-left-right"),
        MovementType.Adjustment => ("Penyesuaian", "badge-light-warning", "bi-sliders"),
        _ => ("-", "badge-light-primary", "")
    };
}

<div class="card">
    <div class="card-header justify-content-between flex-wrap gap-2">
        <span>Riwayat Pergerakan Stok</span>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="In" class="btn btn-sm btn-primary"><i class="bi bi-box-arrow-in-down"></i> Masuk</a>
            <a asp-action="Out" class="btn btn-sm btn-light"><i class="bi bi-box-arrow-up"></i> Keluar</a>
            <a asp-action="Transfer" class="btn btn-sm btn-light"><i class="bi bi-arrow-left-right"></i> Transfer</a>
            <a asp-action="Adjust" class="btn btn-sm btn-light"><i class="bi bi-sliders"></i> Penyesuaian</a>
        </div>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end mb-3">
            <div class="col-sm-4 col-md-3">
                <label class="form-label small fw-semibold mb-1">Jenis</label>
                <select name="type" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Semua jenis</option>
                    @foreach (var t in Enum.GetValues<MovementType>())
                    {
                        <option value="@((int)t)" selected="@(filterType == t)">@TypeInfo(t).Label</option>
                    }
                </select>
            </div>
            <div class="col-sm-5 col-md-4">
                <label class="form-label small fw-semibold mb-1">Produk</label>
                <select name="productId" asp-items="ViewBag.Products" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Semua produk</option>
                </select>
            </div>
            <div class="col-auto">
                <a asp-action="Movements" class="btn btn-sm btn-light">Reset</a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>No. Referensi</th><th>Tanggal</th><th>Jenis</th><th>Produk</th>
                        <th>Gudang</th><th class="text-end">Jumlah</th><th>Catatan</th><th>Oleh</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Belum ada pergerakan stok</td></tr>
                }
                @foreach (var m in Model)
                {
                    var info = TypeInfo(m.Type);
                    <tr>
                        <td class="fw-semibold">@m.ReferenceNumber</td>
                        <td>@m.MovementDate.ToString("dd/MM/yyyy")</td>
                        <td><span class="@info.Css px-2 py-1 rounded"><i class="bi @info.Icon"></i> @info.Label</span></td>
                        <td class="text-dark">@m.Product?.Name</td>
                        <td>
                            @m.Warehouse?.Name
                            @if (m.Type == MovementType.Transfer && m.DestinationWarehouse != null)
                            {
                                <i class="bi bi-arrow-right mx-1 text-muted"></i> @m.DestinationWarehouse.Name
                            }
                        </td>
                        <td class="text-end fw-semibold">
                            @switch (m.Type)
                            {
                                case MovementType.StockIn:
                                    <span class="text-success">+@m.Quantity</span>
                                    break;
                                case MovementType.StockOut:
                                    <span class="text-danger">-@m.Quantity</span>
                                    break;
                                case MovementType.Transfer:
                                    <span>@m.Quantity</span>
                                    break;
                                default:
                                    <span class="@(m.Quantity >= 0 ? "text-success" : "text-danger")">@(m.Quantity >= 0 ? "+" : "")@m.Quantity</span>
                                    break;
                            }
                        </td>
                        <td class="text-muted">@m.Note</td>
                        <td class="text-muted small">@m.CreatedBy</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
