@using ErpMetronic.Domain.Enums
@model List<PurchaseRequisition>
@{ ViewData["Title"] = "Purchase Requisition"; }

@functions {
    (string Label, string Css) Status(PurchaseRequisitionStatus s) => s switch
    {
        PurchaseRequisitionStatus.Draft => ("Draft", "badge-light-warning"),
        PurchaseRequisitionStatus.Submitted => ("Diajukan", "badge-light-primary"),
        PurchaseRequisitionStatus.Approved => ("Disetujui", "badge-light-success"),
        PurchaseRequisitionStatus.Rejected => ("Ditolak", "badge-light-danger"),
        _ => (s.ToString(), "badge-light-primary")
    };
}

<div class="card">
    <div class="card-header justify-content-between">
        <span>Daftar Purchase Requisition</span>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> PR Baru</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>No. PR</th><th>Tanggal</th><th>Diminta Oleh</th><th>Status</th><th class="text-end">Item</th><th class="text-end">Aksi</th></tr></thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-4">Belum ada purchase requisition</td></tr>
            }
            @foreach (var p in Model)
            {
                var st = Status(p.Status);
                <tr>
                    <td class="fw-semibold">@p.ReferenceNumber</td>
                    <td>@p.RequestDate.ToString("dd/MM/yyyy")</td>
                    <td>@p.RequestedBy</td>
                    <td><span class="@st.Css px-2 py-1 rounded">@st.Label</span></td>
                    <td class="text-end">@p.Lines.Count</td>
                    <td class="text-end"><a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-light"><i class="bi bi-eye"></i></a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
