@model PurchaseRequisitionCreateViewModel
@{
    ViewData["Title"] = "Edit PR " + (ViewBag.ReferenceNumber as string);
    var products = ViewBag.Products as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var prId = (int)ViewBag.PrId;
}

<div class="card">
    <div class="card-header"><i class="bi bi-pencil-square text-primary me-2"></i> Edit PR @ViewBag.ReferenceNumber</div>
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@prId" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label asp-for="RequestDate" class="form-label fw-semibold"></label>
                    <input asp-for="RequestDate" type="date" class="form-control" />
                    <span asp-validation-for="RequestDate" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="RequestedBy" class="form-label fw-semibold"></label>
                    <input asp-for="RequestedBy" class="form-control" />
                    <span asp-validation-for="RequestedBy" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Department" class="form-label fw-semibold"></label>
                    <input asp-for="Department" class="form-control" />
                    <span asp-validation-for="Department" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Note" class="form-label fw-semibold"></label>
                    <input asp-for="Note" class="form-control" />
                </div>
            </div>

            <h6 class="fw-semibold">Detail Item</h6>
            <table class="table align-middle" id="linesTable">
                <thead><tr><th style="width:50%">Produk</th><th class="text-end">Jumlah</th><th class="text-end">Estimasi Harga</th><th>Catatan</th><th></th></tr></thead>
                <tbody id="linesBody">
                @for (int i = 0; i < Model.Lines.Count; i++)
                {
                    var it = Model.Lines[i];
                    <tr class="line-row">
                        <td>
                            <select name="Lines[@i].ProductId" class="form-select form-select-sm">
                                <option value="">-- Pilih produk --</option>
                                @foreach (var p in products)
                                {
                                    <option value="@p.Id" selected="@(((int)p.Id) == it.ProductId)">@p.Display</option>
                                }
                            </select>
                        </td>
                        <td><input name="Lines[@i].Quantity" type="number" min="1" value="@it.Quantity" class="form-control form-control-sm text-end" /></td>
                        <td><input name="Lines[@i].EstimatedPrice" type="number" min="0" step="0.01" value="@it.EstimatedPrice" class="form-control form-control-sm text-end" /></td>
                        <td><input name="Lines[@i].Note" value="@it.Note" class="form-control form-control-sm" /></td>
                        <td class="text-end"><button type="button" class="btn btn-sm btn-light text-danger removeLine"><i class="bi bi-x-lg"></i></button></td>
                    </tr>
                }
                </tbody>
            </table>
            <button type="button" class="btn btn-light btn-sm" id="addLine"><i class="bi bi-plus-lg"></i> Tambah Baris</button>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Simpan Perubahan</button>
                <a asp-action="Details" asp-route-id="@prId" class="btn btn-light">Batal</a>
            </div>

            <template id="lineTemplate">
                <tr class="line-row">
                    <td>
                        <select name="Lines[__I__].ProductId" class="form-select form-select-sm">
                            <option value="">-- Pilih produk --</option>
                            @foreach (var p in products)
                            {
                                <option value="@p.Id">@p.Display</option>
                            }
                        </select>
                    </td>
                    <td><input name="Lines[__I__].Quantity" type="number" min="1" value="1" class="form-control form-control-sm text-end" /></td>
                    <td><input name="Lines[__I__].EstimatedPrice" type="number" min="0" step="0.01" value="0" class="form-control form-control-sm text-end" /></td>
                    <td><input name="Lines[__I__].Note" class="form-control form-control-sm" /></td>
                    <td class="text-end"><button type="button" class="btn btn-sm btn-light text-danger removeLine"><i class="bi bi-x-lg"></i></button></td>
                </tr>
            </template>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const body = document.getElementById('linesBody');
        const tpl = document.getElementById('lineTemplate').innerHTML;
        function reindex() {
            body.querySelectorAll('.line-row').forEach(function (row, i) {
                row.querySelectorAll('[name]').forEach(function (el) {
                    el.name = el.name.replace(/Lines\[\d+\]/, 'Lines[' + i + ']').replace(/Lines\[__I__\]/, 'Lines[' + i + ']');
                });
            });
        }
        document.getElementById('addLine').addEventListener('click', function () {
            body.insertAdjacentHTML('beforeend', tpl.replace(/__I__/g, body.children.length));
            reindex();
        });
        body.addEventListener('click', function (e) {
            if (e.target.closest('.removeLine')) { e.target.closest('.line-row').remove(); reindex(); }
        });
    </script>
}
