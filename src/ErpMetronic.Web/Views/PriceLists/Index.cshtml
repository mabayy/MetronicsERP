@model List<ErpMetronic.Domain.Entities.PriceList>
@{ ViewData["Title"] = "Daftar Harga"; }

<div class="card">
    <div class="card-header justify-content-between">
        <span>Daftar Harga</span>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Daftar Harga Baru</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead><tr>
                <th>Kode</th>
                <th>Nama</th>
                <th>Mata Uang</th>
                <th class="text-end">Jumlah Item</th>
                <th>Status</th>
                <th class="text-end">Aksi</th>
            </tr></thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-4">Belum ada data</td></tr>
            }
            @foreach (var p in Model)
            {
                <tr>
                    <td>
                        <span class="badge-light-primary px-2 py-1 rounded">@p.Code</span>
                        @if (p.IsSystem) { <span class="text-muted small ms-1">sistem</span> }
                    </td>
                    <td class="fw-semibold text-dark">@p.Name</td>
                    <td>@(p.Currency?.Code ?? "—")</td>
                    <td class="text-end">@p.Items.Count</td>
                    <td>
                        @if (p.IsActive) { <span class="badge-light-success px-2 py-1 rounded">Aktif</span> }
                        else { <span class="badge-light-secondary px-2 py-1 rounded">Nonaktif</span> }
                    </td>
                    <td class="text-end">
                        <a asp-action="Manage" asp-route-id="@p.Id" class="btn btn-sm btn-light-primary"><i class="bi bi-tags"></i> Harga</a>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-light"><i class="bi bi-pencil"></i></a>
                        @if (!p.IsSystem)
                        {
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus daftar harga ini?');">
                                <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        }
                        else
                        {
                            <span class="btn btn-sm btn-light text-muted disabled"><i class="bi bi-lock"></i></span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
