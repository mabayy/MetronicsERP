@using ErpMetronic.Domain.Enums
@model List<ErpMetronic.Domain.Entities.ApprovalRule>
@{ ViewData["Title"] = "Aturan Persetujuan"; }

<div class="card">
    <div class="card-header justify-content-between">
        <span>Aturan Persetujuan</span>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Aturan Baru</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead><tr>
                <th>Nama</th>
                <th>Dokumen</th>
                <th class="text-end">Ambang</th>
                <th>Langkah</th>
                <th>Status</th>
                <th class="text-end">Aksi</th>
            </tr></thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-4">Belum ada data</td></tr>
            }
            @foreach (var r in Model)
            {
                <tr>
                    <td class="fw-semibold text-dark">@r.Name</td>
                    <td><span class="badge-light-primary px-2 py-1 rounded">@r.DocumentType</span></td>
                    <td class="text-end">&ge; @r.MinAmount.ToString("N2")</td>
                    <td>@string.Join(" → ", r.Steps.OrderBy(s => s.Level).Select(s => s.Position?.Name))</td>
                    <td>
                        @if (r.IsActive) { <span class="badge-light-success px-2 py-1 rounded">Aktif</span> }
                        else { <span class="badge-light-danger px-2 py-1 rounded">Nonaktif</span> }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-light"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus aturan ini?');">
                            <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
