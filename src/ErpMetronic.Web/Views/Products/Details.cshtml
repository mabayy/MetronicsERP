@model Product
@{ ViewData["Title"] = "Detail Produk"; }

<div class="card">
    <div class="card-header justify-content-between">
        <span>Detail Produk</span>
        @if (Model.IsActive) { <span class="badge-light-success px-2 py-1 rounded">Aktif</span> }
        else { <span class="badge-light-danger px-2 py-1 rounded">Nonaktif</span> }
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">SKU</dt>
            <dd class="col-sm-9"><span class="badge-light-primary px-2 py-1 rounded">@Model.Sku</span></dd>

            <dt class="col-sm-3">Nama</dt>
            <dd class="col-sm-9 fw-semibold text-dark">@Model.Name</dd>

            <dt class="col-sm-3">Deskripsi</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Kategori</dt>
            <dd class="col-sm-9">@Model.Category?.Name</dd>

            <dt class="col-sm-3">Satuan</dt>
            <dd class="col-sm-9">@Model.UnitOfMeasure?.Name</dd>

            <dt class="col-sm-3">Harga Beli</dt>
            <dd class="col-sm-9">@Model.PurchasePrice.ToString("N0")</dd>

            <dt class="col-sm-3">Harga Jual</dt>
            <dd class="col-sm-9">@Model.SellingPrice.ToString("N0")</dd>

            <dt class="col-sm-3">Stok</dt>
            <dd class="col-sm-9">
                @if (Model.StockQuantity <= Model.ReorderLevel) { <span class="badge-light-danger px-2 py-1 rounded">@Model.StockQuantity</span> }
                else { <span class="badge-light-success px-2 py-1 rounded">@Model.StockQuantity</span> }
            </dd>

            <dt class="col-sm-3">Level Pemesanan Ulang</dt>
            <dd class="col-sm-9">@Model.ReorderLevel</dd>
        </dl>
        <div class="mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a>
            <a asp-action="Index" class="btn btn-light">Kembali</a>
        </div>
    </div>
</div>
