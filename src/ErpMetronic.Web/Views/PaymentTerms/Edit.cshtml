@model ErpMetronic.Web.ViewModels.PaymentTermCreateViewModel
@{
    ViewData["Title"] = "Edit Termin";
    var isSystem = (bool)ViewBag.IsSystem;
}

<div class="card">
    <div class="card-header">Edit Termin</div>
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@ViewBag.TermId" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            @if (isSystem)
            {
                <div class="alert alert-light border small mb-3"><i class="bi bi-lock me-1"></i> Termin sistem: kode terkunci</div>
            }
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Code" class="form-label fw-semibold"></label>
                    @if (isSystem)
                    {
                        <input asp-for="Code" class="form-control" disabled />
                    }
                    else
                    {
                        <input asp-for="Code" class="form-control" />
                    }
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="NetDays" class="form-label fw-semibold"></label>
                    <input asp-for="NetDays" type="number" min="0" class="form-control" />
                    <span asp-validation-for="NetDays" class="text-danger small"></span>
                </div>
                <div class="col-12 form-check ms-2">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Aktif</label>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Simpan</button>
                <a asp-action="Index" class="btn btn-light">Batal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
