@using ErpMetronic.Domain.Enums
@model TaxCreateViewModel
@{ ViewData["Title"] = "Tambah Pajak"; }

<div class="card">
    <div class="card-header">Form Pajak Baru</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Code" class="form-label fw-semibold"></label>
                    <input asp-for="Code" class="form-control" />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Rate" class="form-label fw-semibold"></label>
                    <input asp-for="Rate" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Rate" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Kind" class="form-label fw-semibold"></label>
                    <select asp-for="Kind" asp-items="Html.GetEnumSelectList<ErpMetronic.Domain.Enums.TaxKind>()" class="form-select"></select>
                    <span asp-validation-for="Kind" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="AppliesTo" class="form-label fw-semibold"></label>
                    <select asp-for="AppliesTo" asp-items="Html.GetEnumSelectList<ErpMetronic.Domain.Enums.TaxApplicability>()" class="form-select"></select>
                    <span asp-validation-for="AppliesTo" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AccountCode" class="form-label fw-semibold"></label>
                    <select asp-for="AccountCode" asp-items="ViewBag.Accounts" class="form-select"><option value="">-- Pilih akun --</option></select>
                    <span asp-validation-for="AccountCode" class="text-danger small"></span>
                </div>
                <div class="col-12 form-check ms-2">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Aktif</label>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Simpan</button>
                <a asp-action="Index" class="btn btn-light">Batal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
