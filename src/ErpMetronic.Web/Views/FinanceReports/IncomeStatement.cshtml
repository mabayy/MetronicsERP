@model ErpMetronic.Web.Controllers.IncomeStatementVm
@{
    ViewData["Title"] = "Laba Rugi";
}

<div class="card">
    <div class="card-header">
        <span><i class="bi bi-graph-up-arrow text-primary me-2"></i> Laba Rugi (@Model.From.ToString("dd/MM/yyyy") – @Model.To.ToString("dd/MM/yyyy"))</span>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end mb-3">
            <div class="col-sm-4 col-md-3">
                <label class="form-label small fw-semibold mb-1">Dari</label>
                <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-4 col-md-3">
                <label class="form-label small fw-semibold mb-1">Sampai</label>
                <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            </div>
            <div class="col-auto"><button type="submit" class="btn btn-sm btn-primary">Tampilkan</button></div>
        </form>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <tbody>
                    <tr class="table-light"><td class="fw-bold" colspan="2">Pendapatan</td></tr>
                    @if (!Model.Revenue.Any()) { <tr><td colspan="2" class="text-muted ps-4">Tidak ada</td></tr> }
                    @foreach (var r in Model.Revenue)
                    {
                        <tr><td class="ps-4"><span class="text-muted small me-2">@r.Code</span>@r.Name</td><td class="text-end">@r.Amount.ToString("N2")</td></tr>
                    }
                    <tr><td class="text-end fw-semibold">Total Pendapatan</td><td class="text-end fw-semibold">@Model.TotalRevenue.ToString("N2")</td></tr>

                    <tr class="table-light"><td class="fw-bold" colspan="2">Beban</td></tr>
                    @if (!Model.Expense.Any()) { <tr><td colspan="2" class="text-muted ps-4">Tidak ada</td></tr> }
                    @foreach (var r in Model.Expense)
                    {
                        <tr><td class="ps-4"><span class="text-muted small me-2">@r.Code</span>@r.Name</td><td class="text-end">@r.Amount.ToString("N2")</td></tr>
                    }
                    <tr><td class="text-end fw-semibold">Total Beban</td><td class="text-end fw-semibold">(@Model.TotalExpense.ToString("N2"))</td></tr>
                </tbody>
                <tfoot>
                    <tr class="table-light">
                        <td class="text-end fw-bold">Laba (Rugi) Bersih</td>
                        <td class="text-end fw-bold @(Model.NetIncome < 0 ? "text-danger" : "text-success")">@Model.NetIncome.ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
