@model MenuItemViewModel
@{
    var divisions = ViewBag.Divisions as List<Division> ?? new List<Division>();
    var positions = ViewBag.Positions as List<Position> ?? new List<Position>();
}
<div class="col-12">
    <label class="form-label fw-semibold">Hak Akses Menu</label>
    <div class="text-muted small mb-2">
        <i class="bi bi-info-circle"></i> Centang divisi/posisi yang boleh mengakses menu ini.
        Bila keduanya dikosongkan, menu <strong>terbuka untuk semua pengguna login</strong>.
        Pengguna boleh akses jika divisi <em>atau</em> posisinya tercentang. Administrator selalu melihat semua menu.
    </div>
    <div class="row g-3">
        <div class="col-md-6">
            <div class="border rounded p-3 h-100">
                <div class="fw-semibold mb-2"><i class="bi bi-diagram-3 me-1"></i> Divisi</div>
                @if (!divisions.Any())
                {
                    <span class="text-muted small">Belum ada divisi.</span>
                }
                @foreach (var d in divisions)
                {
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="DivisionIds" value="@d.Id" id="div-@d.Id"
                               @(Model.DivisionIds.Contains(d.Id) ? "checked" : "") />
                        <label class="form-check-label" for="div-@d.Id">@d.Name</label>
                    </div>
                }
            </div>
        </div>
        <div class="col-md-6">
            <div class="border rounded p-3 h-100">
                <div class="fw-semibold mb-2"><i class="bi bi-person-badge me-1"></i> Posisi</div>
                @if (!positions.Any())
                {
                    <span class="text-muted small">Belum ada posisi.</span>
                }
                @foreach (var p in positions)
                {
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="PositionIds" value="@p.Id" id="pos-@p.Id"
                               @(Model.PositionIds.Contains(p.Id) ? "checked" : "") />
                        <label class="form-check-label" for="pos-@p.Id">@p.Name</label>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
