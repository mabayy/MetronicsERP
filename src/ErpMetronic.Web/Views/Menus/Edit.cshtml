@model MenuItemViewModel
@{
    ViewData["Title"] = "Edit Menu";
}

<div class="card">
    <div class="card-header">
        Edit Menu
        @if (Model.IsSystem) { <span class="badge-light-primary px-2 rounded ms-2">Menu sistem</span> }
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="IsSystem" />
            <input type="hidden" asp-for="RequiredRole" />
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Icon" class="form-label fw-semibold"></label>
                    <input asp-for="Icon" class="form-control" placeholder="contoh: bi-box" />
                    <span class="text-muted small">Lihat daftar ikon di icons.getbootstrap.com (tanpa prefix titik).</span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ParentId" class="form-label fw-semibold"></label>
                    <select asp-for="ParentId" asp-items="ViewBag.Parents" class="form-select">
                        <option value="">(Menu utama / level atas)</option>
                    </select>
                    <span asp-validation-for="ParentId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Controller" class="form-label fw-semibold"></label>
                    <input asp-for="Controller" class="form-control" placeholder="contoh: Products" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Action" class="form-label fw-semibold"></label>
                    <input asp-for="Action" class="form-control" placeholder="Index" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Url" class="form-label fw-semibold"></label>
                    <input asp-for="Url" class="form-control" placeholder="opsional, mis. https://..." />
                </div>
                <div class="col-12">
                    <span class="text-muted small"><i class="bi bi-info-circle"></i> Kosongkan Controller & URL untuk membuat <strong>grup/header</strong>. Jika URL diisi, ia diutamakan.</span>
                </div>
                <partial name="_MenuAccessFields" model="Model" />
                <div class="col-12 form-check ms-2">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Aktif</label>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Perbarui</button>
                <a asp-action="Index" class="btn btn-light">Batal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
