@using ErpMetronic.Domain.Enums
@model ChartOfAccount
@{ ViewData["Title"] = "Tambah Akun"; }

<div class="card">
    <div class="card-header">Form Akun Baru</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Code" class="form-label fw-semibold"></label>
                    <input asp-for="Code" class="form-control" />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Type" class="form-label fw-semibold"></label>
                    <select asp-for="Type" class="form-select">
                        <option value="@((int)AccountType.Asset)">Aset</option>
                        <option value="@((int)AccountType.Liability)">Kewajiban</option>
                        <option value="@((int)AccountType.Equity)">Ekuitas</option>
                        <option value="@((int)AccountType.Revenue)">Pendapatan</option>
                        <option value="@((int)AccountType.Expense)">Beban</option>
                    </select>
                    <span asp-validation-for="Type" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12 form-check ms-2">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Aktif</label>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Simpan</button>
                <a asp-action="Index" class="btn btn-light">Batal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
