@model GoodsReceipt
@{ ViewData["Title"] = "Detail Penerimaan " + Model.ReferenceNumber; }

<div class="card mb-3">
    <div class="card-header justify-content-between">
        <span>Penerimaan @Model.ReferenceNumber</span>
        <span class="badge-light-success px-2 py-1 rounded"><i class="bi bi-check-circle"></i> Terposting ke stok</span>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Tanggal</dt><dd class="col-sm-9">@Model.ReceiptDate.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-3">Pemasok</dt><dd class="col-sm-9">@Model.Supplier?.Name</dd>
            <dt class="col-sm-3">Gudang</dt><dd class="col-sm-9">@Model.Warehouse?.Name</dd>
            <dt class="col-sm-3">Catatan</dt><dd class="col-sm-9">@Model.Note</dd>
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-header">Detail Item</div>
    <div class="card-body p-0">
        <table class="table align-middle mb-0">
            <thead><tr><th>Produk</th><th class="text-end">Jumlah</th><th class="text-end">Harga Beli/unit</th><th class="text-end">Subtotal</th></tr></thead>
            <tbody>
            @foreach (var l in Model.Lines)
            {
                <tr>
                    <td>@l.Product?.Sku — @l.Product?.Name</td>
                    <td class="text-end">@l.Quantity.ToString("N0")</td>
                    <td class="text-end">@l.UnitCost.ToString("N2")</td>
                    <td class="text-end">@((l.Quantity * l.UnitCost).ToString("N2"))</td>
                </tr>
            }
            </tbody>
            <tfoot>
                <tr class="table-light">
                    <td class="fw-bold">Total</td>
                    <td class="text-end fw-bold">@Model.Lines.Sum(l => l.Quantity).ToString("N0")</td>
                    <td></td>
                    <td class="text-end fw-bold">@Model.Lines.Sum(l => l.Quantity * l.UnitCost).ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
<div class="mt-3">
    <a asp-action="Index" class="btn btn-light">Kembali</a>
    <a asp-controller="Stock" asp-action="Movements" class="btn btn-light"><i class="bi bi-clock-history"></i> Lihat Pergerakan Stok</a>
</div>
