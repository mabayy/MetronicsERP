@model GoodsReceiptCreateViewModel
@{
    ViewData["Title"] = "Penerimaan Barang Baru";
    var products = ViewBag.Products as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="card">
    <div class="card-header"><i class="bi bi-arrow-down-square text-primary me-2"></i> Penerimaan Barang (auto Stok Masuk)</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label asp-for="SupplierId" class="form-label fw-semibold"></label>
                    <select asp-for="SupplierId" asp-items="ViewBag.Suppliers" class="form-select"><option value="">-- Pilih pemasok --</option></select>
                    <span asp-validation-for="SupplierId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="WarehouseId" class="form-label fw-semibold"></label>
                    <select asp-for="WarehouseId" asp-items="ViewBag.Warehouses" class="form-select"><option value="">-- Pilih gudang --</option></select>
                    <span asp-validation-for="WarehouseId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ReceiptDate" class="form-label fw-semibold"></label>
                    <input asp-for="ReceiptDate" type="date" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Note" class="form-label fw-semibold"></label>
                    <input asp-for="Note" class="form-control" />
                </div>
            </div>

            <h6 class="fw-semibold">Detail Item</h6>
            <div class="lines-scroll">
            <table class="table align-middle" id="linesTable">
                <thead><tr><th style="width:55%">Produk</th><th class="text-end">Jumlah</th><th class="text-end">Harga Beli/unit</th><th></th></tr></thead>
                <tbody id="linesBody"></tbody>
            </table>
            </div>
            <button type="button" class="btn btn-light btn-sm" id="addLine"><i class="bi bi-plus-lg"></i> Tambah Baris</button>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Simpan & Posting Stok</button>
                <a asp-action="Index" class="btn btn-light">Batal</a>
            </div>

            <template id="lineTemplate">
                <tr class="line-row">
                    <td>
                        <select name="Lines[__I__].ProductId" class="form-select form-select-sm">
                            <option value="">-- Pilih produk --</option>
                            @foreach (var p in products)
                            {
                                <option value="@p.Id">@p.Display</option>
                            }
                        </select>
                    </td>
                    <td><input name="Lines[__I__].Quantity" type="number" min="1" value="1" class="form-control form-control-sm text-end" /></td>
                    <td><input name="Lines[__I__].UnitCost" type="number" min="0" step="0.01" value="0" class="form-control form-control-sm text-end" /></td>
                    <td class="text-end"><button type="button" class="btn btn-sm btn-light text-danger removeLine"><i class="bi bi-x-lg"></i></button></td>
                </tr>
            </template>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const body = document.getElementById('linesBody');
        const tpl = document.getElementById('lineTemplate').innerHTML;
        function reindex() {
            body.querySelectorAll('.line-row').forEach(function (row, i) {
                row.querySelectorAll('[name]').forEach(function (el) {
                    el.name = el.name.replace(/Lines\[\d+\]/, 'Lines[' + i + ']').replace(/Lines\[__I__\]/, 'Lines[' + i + ']');
                });
            });
        }
        function addLine() { body.insertAdjacentHTML('beforeend', tpl.replace(/__I__/g, body.children.length)); reindex(); }
        document.getElementById('addLine').addEventListener('click', addLine);
        body.addEventListener('click', function (e) {
            if (e.target.closest('.removeLine')) { e.target.closest('.line-row').remove(); reindex(); }
        });
        addLine(); // satu baris awal
    </script>
}
