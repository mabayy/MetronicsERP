@using ErpMetronic.Domain.Enums
@model SalesOrder
@{
    ViewData["Title"] = "SO " + Model.ReferenceNumber;
    var deliveries = ViewBag.Deliveries as List<DeliveryOrder> ?? new();
    var total = Model.Items.Sum(i => i.Quantity * i.UnitPrice);
    var curCode = Model.Currency?.Code;
    (string Label, string Css) St(SalesOrderStatus s) => s switch
    {
        SalesOrderStatus.Draft => ("Draft", "badge-light-warning"),
        SalesOrderStatus.Confirmed => ("Dikonfirmasi", "badge-light-primary"),
        SalesOrderStatus.PartiallyDelivered => ("Terkirim Sebagian", "badge-light-warning"),
        SalesOrderStatus.Delivered => ("Terkirim", "badge-light-success"),
        SalesOrderStatus.Cancelled => ("Dibatalkan", "badge-light-danger"),
        _ => (s.ToString(), "badge-light-primary")
    };
    var st = St(Model.Status);
    var canDeliver = Model.Status is SalesOrderStatus.Confirmed or SalesOrderStatus.PartiallyDelivered;
    var canCancel = Model.Status is SalesOrderStatus.Draft or SalesOrderStatus.Confirmed && Model.Items.All(i => i.DeliveredQuantity == 0);
}

<div class="card mb-3">
    <div class="card-header justify-content-between">
        <span>Sales Order @Model.ReferenceNumber</span>
        <span class="@st.Css px-2 py-1 rounded">@st.Label</span>
    </div>
    <div class="card-body">
        <dl class="row mb-3">
            <dt class="col-sm-3">Tanggal</dt><dd class="col-sm-9">@Model.OrderDate.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-3">Pelanggan</dt><dd class="col-sm-9">@Model.Customer?.Name</dd>
            <dt class="col-sm-3">Gudang Sumber</dt><dd class="col-sm-9">@Model.Warehouse?.Name</dd>
            <dt class="col-sm-3">Mata Uang</dt><dd class="col-sm-9">@(Model.Currency?.Code ?? "—")</dd>
            <dt class="col-sm-3">Catatan</dt><dd class="col-sm-9">@Model.Note</dd>
        </dl>
        <div class="d-flex gap-2 flex-wrap">
            @if (Model.Status == SalesOrderStatus.Draft)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-light btn-sm"><i class="bi bi-pencil"></i> Edit</a>
                <form asp-action="Confirm" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Konfirmasi SO ini?');">
                    <button class="btn btn-primary btn-sm"><i class="bi bi-check2-circle"></i> Konfirmasi (Dikonfirmasi)</button>
                </form>
            }
            @if (canDeliver)
            {
                <a asp-action="Deliver" asp-route-id="@Model.Id" class="btn btn-success btn-sm"><i class="bi bi-box-arrow-up"></i> Kirim Barang</a>
            }
            @if (canCancel)
            {
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Batalkan SO ini?');">
                    <button class="btn btn-light btn-sm text-danger"><i class="bi bi-x-circle"></i> Batalkan</button>
                </form>
            }
            <a asp-action="Index" class="btn btn-light btn-sm">Kembali</a>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Item SO</div>
    <div class="card-body p-0">
        <table class="table align-middle mb-0">
            <thead><tr><th>Produk</th><th class="text-end">Dipesan</th><th class="text-end">Terkirim</th><th class="text-end">Sisa</th><th class="text-end">Harga Satuan</th><th class="text-end">Subtotal</th></tr></thead>
            <tbody>
            @foreach (var i in Model.Items)
            {
                <tr>
                    <td>@i.Product?.Sku — @i.Product?.Name</td>
                    <td class="text-end">@i.Quantity.ToString("N0")</td>
                    <td class="text-end">@i.DeliveredQuantity.ToString("N0")</td>
                    <td class="text-end">@i.OutstandingQuantity.ToString("N0")</td>
                    <td class="text-end">@curCode @i.UnitPrice.ToString("N2")</td>
                    <td class="text-end">@curCode @((i.Quantity * i.UnitPrice).ToString("N2"))</td>
                </tr>
            }
            </tbody>
            <tfoot>
                <tr class="table-light"><td colspan="5" class="text-end fw-bold">Total</td><td class="text-end fw-bold">@curCode @total.ToString("N2")</td></tr>
            </tfoot>
        </table>
    </div>
</div>

<div class="card">
    <div class="card-header">Riwayat Pengiriman</div>
    <div class="card-body p-0">
        <table class="table align-middle mb-0">
            <thead><tr><th>No. Pengiriman</th><th>Tanggal</th><th>Gudang</th><th class="text-end">Total Qty</th><th class="text-end">Aksi</th></tr></thead>
            <tbody>
            @if (!deliveries.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-3">Belum ada pengiriman</td></tr>
            }
            @foreach (var g in deliveries)
            {
                <tr>
                    <td class="fw-semibold">@g.ReferenceNumber</td>
                    <td>@g.DeliveryDate.ToString("dd/MM/yyyy")</td>
                    <td>@g.Warehouse?.Name</td>
                    <td class="text-end">@g.Lines.Sum(l => l.Quantity).ToString("N0")</td>
                    <td class="text-end"><a asp-controller="DeliveryOrders" asp-action="Details" asp-route-id="@g.Id" class="btn btn-sm btn-light"><i class="bi bi-eye"></i></a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
