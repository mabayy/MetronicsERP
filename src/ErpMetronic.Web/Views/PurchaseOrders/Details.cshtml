@using ErpMetronic.Domain.Enums
@model PurchaseOrder
@{
    ViewData["Title"] = "PO " + Model.ReferenceNumber;
    var receipts = ViewBag.Receipts as List<GoodsReceipt> ?? new();
    var total = Model.Items.Sum(i => i.Quantity * i.UnitPrice);
    var curCode = Model.Currency?.Code;
    (string Label, string Css) St(PurchaseOrderStatus s) => s switch
    {
        PurchaseOrderStatus.Draft => ("Draft", "badge-light-warning"),
        PurchaseOrderStatus.Ordered => ("Dipesan", "badge-light-primary"),
        PurchaseOrderStatus.PartiallyReceived => ("Diterima Sebagian", "badge-light-warning"),
        PurchaseOrderStatus.Received => ("Diterima", "badge-light-success"),
        PurchaseOrderStatus.Cancelled => ("Dibatalkan", "badge-light-danger"),
        _ => (s.ToString(), "badge-light-primary")
    };
    var st = St(Model.Status);
    var canReceive = Model.Status is PurchaseOrderStatus.Ordered or PurchaseOrderStatus.PartiallyReceived;
    var canCancel = Model.Status is PurchaseOrderStatus.Draft or PurchaseOrderStatus.Ordered && Model.Items.All(i => i.ReceivedQuantity == 0);
}

<div class="card mb-3">
    <div class="card-header justify-content-between">
        <span>Purchase Order @Model.ReferenceNumber</span>
        <span class="@st.Css px-2 py-1 rounded">@st.Label</span>
    </div>
    <div class="card-body">
        <dl class="row mb-3">
            <dt class="col-sm-3">Tanggal</dt><dd class="col-sm-9">@Model.OrderDate.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-3">Pemasok</dt><dd class="col-sm-9">@Model.Supplier?.Name</dd>
            <dt class="col-sm-3">Gudang Tujuan</dt><dd class="col-sm-9">@Model.Warehouse?.Name</dd>
            <dt class="col-sm-3">Mata Uang</dt><dd class="col-sm-9">@(Model.Currency?.Code ?? "—")</dd>
            <dt class="col-sm-3">Catatan</dt><dd class="col-sm-9">@Model.Note</dd>
        </dl>
        <div class="d-flex gap-2 flex-wrap">
            @if (Model.Status == PurchaseOrderStatus.Draft)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-light btn-sm"><i class="bi bi-pencil"></i> Edit</a>
                <form asp-action="Confirm" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Konfirmasi PO ini?');">
                    <button class="btn btn-primary btn-sm"><i class="bi bi-check2-circle"></i> Konfirmasi (Ordered)</button>
                </form>
            }
            @if (canReceive)
            {
                <a asp-action="Receive" asp-route-id="@Model.Id" class="btn btn-success btn-sm"><i class="bi bi-box-arrow-in-down"></i> Terima Barang</a>
            }
            @if (Model.Status is PurchaseOrderStatus.PartiallyReceived or PurchaseOrderStatus.Received)
            {
                <a asp-controller="PurchaseInvoices" asp-action="Create" asp-route-poId="@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-arrow-up-right-square"></i> Salin ke Faktur</a>
            }
            @if (canCancel)
            {
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Batalkan PO ini?');">
                    <button class="btn btn-light btn-sm text-danger"><i class="bi bi-x-circle"></i> Batalkan</button>
                </form>
            }
            <a asp-action="Index" class="btn btn-light btn-sm">Kembali</a>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Item PO</div>
    <div class="card-body p-0">
        <table class="table align-middle mb-0">
            <thead><tr><th>Produk</th><th class="text-end">Dipesan</th><th class="text-end">Diterima</th><th class="text-end">Sisa</th><th class="text-end">Harga Satuan</th><th class="text-end">Disk</th><th>PPN</th><th class="text-end">Jumlah</th></tr></thead>
            <tbody>
            @foreach (var i in Model.Items)
            {
                <tr>
                    <td>@i.Product?.Sku — @i.Product?.Name</td>
                    <td class="text-end">@i.Quantity.ToString("N0")</td>
                    <td class="text-end">@i.ReceivedQuantity.ToString("N0")</td>
                    <td class="text-end">@i.OutstandingQuantity.ToString("N0")</td>
                    <td class="text-end">@curCode @i.UnitPrice.ToString("N2")</td>
                    <td class="text-end">@(i.DiscountPercent > 0 ? i.DiscountPercent.ToString("0.##") + "%" : "—")</td>
                    <td><span class="text-muted small">@(i.Tax?.Code ?? "—")</span> <span class="text-end">@i.TaxAmount.ToString("N2")</span></td>
                    <td class="text-end">@curCode @i.LineNet.ToString("N2")</td>
                </tr>
            }
            </tbody>
            <tfoot>
                @if (Model.HeaderDiscountAmount > 0)
                {
                    <tr><td colspan="7" class="text-end fw-semibold">Subtotal</td><td class="text-end">@curCode @Model.NetBeforeHeaderDiscount.ToString("N2")</td></tr>
                    <tr><td colspan="7" class="text-end fw-semibold text-danger">Diskon Header (@Model.HeaderDiscountPercent.ToString("0.##")%)</td><td class="text-end text-danger">−@curCode @Model.HeaderDiscountAmount.ToString("N2")</td></tr>
                }
                <tr><td colspan="7" class="text-end fw-semibold">DPP</td><td class="text-end">@curCode @Model.Subtotal.ToString("N2")</td></tr>
                <tr><td colspan="7" class="text-end fw-semibold">PPN</td><td class="text-end">@curCode @Model.TaxTotal.ToString("N2")</td></tr>
                @if (Model.WithholdingAmount > 0)
                {
                    <tr><td colspan="7" class="text-end fw-semibold text-danger">PPh @(Model.WithholdingTax?.Code)</td><td class="text-end text-danger">−@curCode @Model.WithholdingAmount.ToString("N2")</td></tr>
                }
                <tr class="table-light"><td colspan="7" class="text-end fw-bold">Total</td><td class="text-end fw-bold">@curCode @Model.GrandTotal.ToString("N2")</td></tr>
            </tfoot>
        </table>
    </div>
</div>

<div class="card">
    <div class="card-header">Riwayat Penerimaan</div>
    <div class="card-body p-0">
        <table class="table align-middle mb-0">
            <thead><tr><th>No. Penerimaan</th><th>Tanggal</th><th>Gudang</th><th class="text-end">Total Qty</th><th class="text-end">Aksi</th></tr></thead>
            <tbody>
            @if (!receipts.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-3">Belum ada penerimaan</td></tr>
            }
            @foreach (var g in receipts)
            {
                <tr>
                    <td class="fw-semibold">@g.ReferenceNumber</td>
                    <td>@g.ReceiptDate.ToString("dd/MM/yyyy")</td>
                    <td>@g.Warehouse?.Name</td>
                    <td class="text-end">@g.Lines.Sum(l => l.Quantity).ToString("N0")</td>
                    <td class="text-end"><a asp-controller="GoodsReceipts" asp-action="Details" asp-route-id="@g.Id" class="btn btn-sm btn-light"><i class="bi bi-eye"></i></a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
