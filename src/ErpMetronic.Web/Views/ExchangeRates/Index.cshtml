@model List<ExchangeRate>
@{
    ViewData["Title"] = "Kurs / Exchange Rate";
    var baseCur = ViewBag.BaseCurrency as Currency;
}

<div class="card">
    <div class="card-header justify-content-between">
        <div>
            <span>Daftar Kurs</span>
            @if (baseCur != null)
            {
                <small class="text-muted ms-2">Konvensi: nilai = jumlah <strong>@baseCur.Code</strong> untuk 1 unit mata uang asing</small>
            }
        </div>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Tambah Kurs</a>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end mb-3">
            <div class="col-sm-5 col-md-4">
                <label class="form-label small fw-semibold mb-1">Mata Uang</label>
                <select name="currencyId" asp-items="ViewBag.Currencies" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Semua mata uang</option>
                </select>
            </div>
            <div class="col-auto"><a asp-action="Index" class="btn btn-sm btn-light">Reset</a></div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead><tr><th>Mata Uang</th><th class="text-end">Kurs (ke dasar)</th><th>Berlaku Sejak</th><th>Dicatat Oleh</th><th class="text-end">Aksi</th></tr></thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Belum ada kurs</td></tr>
                }
                @foreach (var r in Model)
                {
                    <tr>
                        <td>
                            <span class="badge-light-primary px-2 py-1 rounded">@r.Currency?.Code</span>
                            <span class="text-dark ms-1">@r.Currency?.Name</span>
                        </td>
                        <td class="text-end fw-semibold">@r.Rate.ToString("N4")</td>
                        <td>@r.EffectiveDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-muted small">@r.CreatedBy</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-light"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus kurs ini?');">
                                <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
