@model List<UserListItemViewModel>
@{ ViewData["Title"] = "Pengguna"; }

<div class="card">
    <div class="card-header justify-content-between">
        <span>Daftar Pengguna</span>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Tambah Pengguna</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>Nama</th><th>Email</th><th>Role</th><th>Status</th><th class="text-end">Aksi</th></tr></thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">Belum ada data</td></tr>
            }
            @foreach (var u in Model)
            {
                <tr>
                    <td class="fw-semibold text-dark">@u.FullName</td>
                    <td>@u.Email</td>
                    <td>
                        @foreach (var role in u.Roles)
                        {
                            <span class="badge-light-primary px-2 py-1 rounded">@role</span>
                        }
                    </td>
                    <td>
                        @if (u.IsActive) { <span class="badge-light-success px-2 py-1 rounded">Aktif</span> }
                        else { <span class="badge-light-danger px-2 py-1 rounded">Nonaktif</span> }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-light"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus pengguna ini?');">
                            <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
