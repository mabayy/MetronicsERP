@model List<RoleViewModel>
@{ ViewData["Title"] = "Role"; }

<div class="card">
    <div class="card-header justify-content-between">
        <span>Daftar Role</span>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Tambah Role</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>Nama Role</th><th>Deskripsi</th><th>Jumlah Pengguna</th><th class="text-end">Aksi</th></tr></thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="4" class="text-center text-muted py-4">Belum ada data</td></tr>
            }
            @foreach (var r in Model)
            {
                <tr>
                    <td class="fw-semibold text-dark">@r.Name</td>
                    <td>@r.Description</td>
                    <td><span class="badge-light-primary px-2 py-1 rounded">@r.UserCount</span></td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-light"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus role ini?');">
                            <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
