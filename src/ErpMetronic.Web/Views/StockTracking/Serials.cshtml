@model List<ErpMetronic.Domain.Entities.SerialNumber>
@{
    ViewData["Title"] = "Nomor Seri";
    var status = ViewBag.Status as string;
}

<div class="card">
    <div class="card-header"><i class="bi bi-upc-scan text-primary me-2"></i> Nomor Seri</div>
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end mb-3">
            <div class="col-auto">
                <label class="form-label small fw-semibold mb-1">Status</label>
                <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="" selected="@(string.IsNullOrEmpty(status))">Semua</option>
                    <option value="in" selected="@(status == "in")">Di Stok</option>
                    <option value="out" selected="@(status == "out")">Keluar</option>
                </select>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead><tr><th>Produk</th><th>No. Seri</th><th>Gudang</th><th>Status</th></tr></thead>
                <tbody>
                @if (!Model.Any()) { <tr><td colspan="4" class="text-center text-muted py-4">Belum ada nomor seri</td></tr> }
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="fw-semibold text-dark">@s.Product?.Sku — @s.Product?.Name</td>
                        <td><span class="badge-light-primary px-2 py-1 rounded">@s.SerialNo</span></td>
                        <td>@(s.Warehouse?.Name ?? "—")</td>
                        <td>
                            @if (s.IsInStock) { <span class="badge-light-success px-2 py-1 rounded">Di Stok</span> }
                            else { <span class="badge-light-secondary px-2 py-1 rounded">Keluar</span> }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
